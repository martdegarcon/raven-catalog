# Локально: SQLite. На Vercel: URL от Turso (libsql://xxx.turso.io)
DATABASE_URL=file:./payload.db
# Только для Turso (продакшен). Локально не задавать.
# DATABASE_AUTH_TOKEN=

PAYLOAD_SECRET=your-payload-secret

# Public URLs: локально localhost, на проде — см. DEPLOY.md (ландинг + каталог)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_LANDING_URL=http://localhost:3000
# Вариант A — каталог на поддомене: NEXT_PUBLIC_APP_URL=https://catalog.raven-custom.com, NEXT_PUBLIC_LANDING_URL=https://raven-custom.com
# Вариант B — каталог по пути /catalog: NEXT_PUBLIC_BASE_PATH=/catalog, NEXT_PUBLIC_APP_URL=https://raven-custom.com/catalog, NEXT_PUBLIC_LANDING_URL=https://raven-custom.com
# NEXT_PUBLIC_BASE_PATH=

# S3 (Reg.ru) — медиа хранятся в объектном хранилище Рег.ру
# Плагин включается только если задан S3_BUCKET
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=ru-1
# S3_ENDPOINT=https://s3.regru.cloud
# S3_FORCE_PATH_STYLE=true

# Email / Resend
ORDER_EMAIL=info@raven-custom.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@raven-custom.com
